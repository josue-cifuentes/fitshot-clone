generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// User profile linked to Strava.
model UserProfile {
  id                String    @id @default(cuid())
  stravaAthleteId   Int       @unique
  stravaEmail       String?
  stravaUsername    String?
  stravaDisplayName String?
  
  /// Encrypted Strava OAuth refresh token for background tasks.
  stravaRefreshCipher String?
  stravaRefreshIv     String?
  stravaRefreshTag    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  calorieEntries CalorieEntry[]
  
  // New fields for calorie tracking
  weightKg          Float?
  heightCm          Float?
  age               Int?
  activityLevel     String?
  dailyDeficitGoal  Int?
  bmr               Float?
  tdee              Float?
  targetCalories    Int?
  telegramChatId    String?   @unique
}

/// Calorie tracking entries for the Weekly Calorie Tracker.
model CalorieEntry {
  id            String      @id @default(cuid())
  userProfileId String
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  
  /// Type of meal: breakfast, lunch, dinner, snack
  type          String
  calories      Int
  description   String?
  
  /// JSON string of food items and their individual calories
  itemsJson     String?
  
  /// Date of the entry
  date          DateTime    @default(now())
  
  createdAt     DateTime    @default(now())

  @@index([userProfileId, date])
}

model TelegramState {
  id             String   @id @default(cuid())
  telegramChatId String   @unique
  userProfileId  String?
  state          String   // e.g., "AWAITING_SIZES", "AWAITING_DEFICIT", etc.
  context        String?  @db.Text // JSON context for the current flow
  updatedAt      DateTime @updatedAt
}
