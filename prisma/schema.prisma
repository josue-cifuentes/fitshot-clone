generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// User profile linked to Strava.
model UserProfile {
  id                String    @id @default(cuid())
  stravaAthleteId   Int       @unique
  stravaEmail       String?
  stravaUsername    String?
  stravaDisplayName String?
  
  /// Encrypted Strava OAuth refresh token for background tasks.
  stravaRefreshCipher String?
  stravaRefreshIv     String?
  stravaRefreshTag    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  calorieEntries CalorieEntry[]
}

/// Calorie tracking entries for the Weekly Calorie Tracker.
model CalorieEntry {
  id            String      @id @default(cuid())
  userProfileId String
  userProfile   UserProfile @relation(fields: [userProfileId], references: [id], onDelete: Cascade)
  
  /// Type of meal: breakfast, lunch, dinner, snack
  type          String
  calories      Int
  description   String?
  
  /// Date of the entry
  date          DateTime    @default(now())
  
  createdAt     DateTime    @default(now())

  @@index([userProfileId, date])
}
