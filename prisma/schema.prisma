generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// Coach data: one row per Strava account. `stravaAthleteId` comes from OAuth and
/// isolates users — each Strava athlete has their own row (no shared global profile).
model CoachProfile {
  id                    String    @id @default(cuid())
  stravaAthleteId       Int       @unique
  garminEmail           String?
  /// AES-GCM encrypted Garmin password (base64)
  garminPasswordCipher  String?
  garminPasswordIv      String?
  garminPasswordTag     String?
  /// Encrypted JSON: Garmin OAuth tokens after successful login (optional)
  garminTokensCipher    String?
  garminTokensIv        String?
  garminTokensTag       String?
  telegramChatId        String?
  /// One-time deep-link token for t.me/Bot?start=… account linking.
  telegramLinkToken     String?   @unique
  lastRecommendationJson String?
  lastRecommendationAt  DateTime?
  /// Encrypted Strava OAuth refresh token (for server/cron without browser cookies).
  stravaRefreshCipher   String?
  stravaRefreshIv       String?
  stravaRefreshTag      String?
  /// Secret token for Health Auto Export webhook (`/api/health/apple?token=…`).
  healthExportToken     String?   @unique
  /// JSON array of daily Apple Health snapshots (last ~14 days, merged by date).
  appleHealthDaysJson   String?
  appleHealthLastSyncAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}
