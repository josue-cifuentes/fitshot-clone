generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// User profile linked to Strava.
model UserProfile {
  id                String    @id @default(cuid())
  stravaAthleteId   Int       @unique
  stravaEmail       String?
  stravaUsername    String?
  stravaDisplayName String?
  
  /// Encrypted Strava OAuth refresh token for background tasks.
  stravaRefreshCipher String?
  stravaRefreshIv     String?
  stravaRefreshTag    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  calorieEntries CalorieEntry[]
  
  // New fields for calorie tracking
  weightKg          Float?
  heightCm          Float?
  age               Int?
  activityLevel     String?
  dailyDeficitGoal  Int?
  bmr               Float?
  tdee              Float?
  targetCalories    Int?
  telegramChatId    String?   @unique
}

/// Calorie tracking entries for the Weekly Calorie Tracker.
model CalorieEntry {
  id              String       @id @default(cuid())
  userProfileId   String?
  userProfile     UserProfile? @relation(fields: [userProfileId], references: [id], onDelete: Cascade)

  /// Telegram chat id when the entry was logged from the bot (works without a linked Strava profile).
  telegramChatId String?

  /// Type of meal: breakfast, lunch, dinner, snack
  type          String
  calories      Int
  description   String?

  /// JSON string of food items and their individual calories
  itemsJson     String?

  /// Date of the entry
  date          DateTime    @default(now())

  createdAt     DateTime    @default(now())

  @@index([userProfileId, date])
  @@index([telegramChatId, date])
}

model TelegramSession {
  id         String   @id @default(cuid())
  chatId     String   @unique
  state      String   @default("idle") // "idle" | "meal_logging"
  foodItems  Json?
  /// Stored demographics for BMR/TDEE (heightCm, weightKg, age, sex, activityLevel, etc.)
  userData   Json?
  mealType   String?
  /// "meal_type" | "portions" — next step in the meal logging flow
  waitingFor String?
  /// Per-chat Google Spreadsheet ID (optional; falls back to GOOGLE_SHEET_ID env)
  sheetId    String?
  updatedAt  DateTime @updatedAt
}
